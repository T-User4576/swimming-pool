# =============================================================================
# Lakehouse repo .gitignore
# =============================================================================

# --- Python (PySpark jobs in iceberg/spark/, possibly more) ---------------
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
.pytest_cache/
.mypy_cache/
.ruff_cache/
.tox/
.venv/
venv/
env/
.python-version

# --- Helm / Kubernetes ----------------------------------------------------
*.tgz
charts/
Chart.lock
kubeconfig
*.kubeconfig

# --- Secrets ---------------------------------------------------------------
# Never commit real credentials. Example templates (*.example.yaml /
# *.example.json) are allowed and explicitly not ignored here.
*credentials.yaml
*credentials.json
*-secrets.yaml
secrets/*.yaml
secrets/*.json
!secrets/*.example.yaml
!secrets/*.example.json
.env
.env.*
!.env.example

# --- Terraform (if it ever shows up) --------------------------------------
.terraform/
*.tfstate
*.tfstate.backup
*.tfvars
!*.tfvars.example
.terraform.lock.hcl

# --- Spark / Iceberg local artefacts --------------------------------------
spark-warehouse/
metastore_db/
derby.log
*.crc

# --- Editors / IDEs -------------------------------------------------------
.idea/
.vscode/
*.swp
*.swo
*~
.project
.classpath
.settings/

# --- OS clutter -----------------------------------------------------------
.DS_Store
Thumbs.db
ehthumbs.db
Desktop.ini

# --- Claude Code local settings -------------------------------------------
.claude/

# --- Logs / temp files ----------------------------------------------------
*.log
*.tmp
logs/
tmp/
